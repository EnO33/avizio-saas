{
  "name": "avizio-saas",
  "version": "0.0.0",
  "description": "SaaS B2B de gestion et de réponse aux avis clients pour commerces de proximité.",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "NODE_ENV=production vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "check:fix": "biome check --write",
    "check:all": "bun run typecheck && bun run check && bun run test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "trigger:dev": "trigger dev",
    "trigger:deploy": "trigger deploy",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "^1.1.3",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@trigger.dev/sdk": "4.4.4",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^1.8.0",
    "neverthrow": "^8.2.0",
    "nitro": "npm:nitro-nightly@latest",
    "pino": "^10.3.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.73.1",
    "tailwindcss": "^4.1.18",
    "ts-pattern": "^5.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@trigger.dev/build": "4.4.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "trigger.dev": "4.4.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc,css}": "biome check --write --no-errors-on-unmatched"
  },
  "trustedDependencies": [
    "@clerk/shared"
  ],
  "overrides": {
    "systeminformation": "^5.27.14"
  }
}
