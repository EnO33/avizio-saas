# Neon Postgres — pointer vers une branche Neon (dev perso, staging, ou prod)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Environnement de runtime — development | test | production.
# LOCAL UNIQUEMENT. Ne PAS mettre cette variable dans les env vars Vercel :
#  - Vercel la gère automatiquement (production sur main, preview sur les PRs).
#  - Si tu la forces à "development" en prod, le bundle utilise le runtime JSX dev
#    de React et SSR crash au boot (jsxDEV is not a function).
# Le script `build` force NODE_ENV=production en local pour protéger du cas "je build
# avec .env chargé" — même raison.
NODE_ENV=development

# Clerk — Authentification + Organizations (dashboard.clerk.com → API keys)
CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_

# Chiffrement des OAuth tokens au repos (AES-256-GCM, rotation par version).
# Generer une clé: bun -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
# Format JSON: { "v1": "<base64-32-bytes>", "v2": "<base64-32-bytes>" }. Au moins v1 requis.
# Rotation: ajouter v2, passer ENCRYPTION_KEY_CURRENT=v2, re-chiffrer progressivement, retirer v1.
ENCRYPTION_KEYS_JSON={"v1":""}
ENCRYPTION_KEY_CURRENT=v1
